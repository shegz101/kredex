# Caddy auto-HTTPS for Kredex.
# Serves kredex.xyz (and www) over HTTPS with free, auto-renewing Let's Encrypt
# certs, and reverse-proxies everything to the internal nginx `web` container.
# flush_interval -1 keeps the SSE chat stream flowing token-by-token.
#
# DNS for kredex.xyz must point at this server before first deploy, or cert
# issuance will fail (Caddy retries automatically once DNS resolves).

kredex.xyz, www.kredex.xyz {
	reverse_proxy web:80 {
		flush_interval -1
	}
}

# Direct Alibaba Cloud server address over plain HTTP (no forced HTTPS redirect,
# since there's no cert for a bare IP). Keeps the raw server reachable as a
# deployment reference alongside the domain.
http://8.222.241.247 {
	reverse_proxy web:80 {
		flush_interval -1
	}
}
