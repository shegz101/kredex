# Deployment secrets for docker-compose (root of repo).
# Copy to .env on the ECS box:  cp .env.example .env   (.env is gitignored)
#
# MONGODB_URI is NOT set here — compose points the server at the mongo
# container automatically (mongodb://mongo:27017/kredex).

# --- Qwen Cloud (Alibaba Model Studio / DashScope) ---
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- Auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
