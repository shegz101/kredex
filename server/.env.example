# Copy this file to .env and fill in real values.  (.env is gitignored — never commit secrets.)

# --- Qwen Cloud (DashScope / Model Studio) ---
# Get this from the Alibaba Cloud Model Studio console (your $40 voucher account).
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI-compatible endpoint. Use the international one unless told otherwise.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- MongoDB ---
# MongoDB Atlas free cluster:  mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/kredex
# or local:                    mongodb://127.0.0.1:27017/kredex
MONGODB_URI=mongodb://127.0.0.1:27017/kredex

# --- Auth ---
# Any long random string. Generate one:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- Server ---
PORT=3001
